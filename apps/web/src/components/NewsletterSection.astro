---
import { Button } from "@workspace/ui/components/button"
import { Input } from "@workspace/ui/components/input"
---

<section class="max-w-3xl mx-auto px-margin-mobile py-section-gap text-center">
<h3 class="font-headline-lg text-headline-lg uppercase mb-6">THE ARCHIVE CLUB</h3>
<p class="font-body-md text-secondary mb-10">Subscribe to receive private access to new collections and exclusive editorial content.</p>
<div class="flex flex-col sm:flex-row gap-0 border border-black">
<Input className="rounded-none flex-1 px-6 py-5 h-auto bg-transparent border-none focus-visible:ring-0 font-label-caps text-label-caps placeholder:text-zinc-400" placeholder="EMAIL ADDRESS" type="email" />
<Button className="rounded-none px-10 py-5 h-auto bg-black !text-white font-label-caps text-label-caps hover:!bg-white hover:!text-black transition-colors uppercase">JOIN</Button>
</div>
</section>
