---
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/index.html';
const isCatalog = pathname.startsWith('/catalog');
const isBlog = pathname.startsWith('/blog');

const activeClass = "font-['Inter'] uppercase tracking-[0.2em] text-[12px] font-medium text-zinc-900 dark:text-zinc-50 border-b border-zinc-900 dark:border-zinc-50 pb-1";
const inactiveClass = "font-['Inter'] uppercase tracking-[0.2em] text-[12px] font-medium text-zinc-400 dark:text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-50 transition-colors duration-300";

// Check if user is logged in
const sessionCookie = Astro.cookies.get("session");
const isLoggedIn = !!sessionCookie;
const username = sessionCookie ? sessionCookie.value : "";
---
<nav class="fixed top-0 w-full z-50 border-b border-zinc-900 dark:border-zinc-50 bg-white dark:bg-zinc-950 flex justify-between items-center h-20 px-8 md:px-16">
<div class="flex-1 flex gap-8 items-center hidden md:flex">
<a class={isHome ? activeClass : inactiveClass} href="/">HOME</a>
<a class={isCatalog ? activeClass : inactiveClass} href="/catalog">COLLECTIONS</a>
<a class={isBlog ? activeClass : inactiveClass} href="/blog">BLOG</a>
</div>
<div class="flex-none">
<a href="/" class="text-2xl font-black tracking-[0.3em] text-zinc-900 dark:text-zinc-50 uppercase block hover:opacity-85 transition-opacity">BAJOEBYYU</a>
</div>
<div class="flex-1 flex justify-end items-center gap-6">
<div class="hidden lg:block font-['Inter'] uppercase tracking-[0.2em] text-[12px] font-medium text-zinc-400 dark:text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-50 transition-colors duration-300 cursor-pointer"><br></div>
<!-- <span class="material-symbols-outlined text-zinc-900 dark:text-zinc-50 cursor-pointer hover:opacity-70 transition-opacity duration-300">search</span> -->
<!-- <span class="material-symbols-outlined text-zinc-900 dark:text-zinc-50 cursor-pointer hover:opacity-70 transition-opacity duration-300">shopping_bag</span> -->

{isLoggedIn ? (
  <div class="relative inline-block text-left" id="user-menu-container">
    <button type="button" id="user-menu-button" class="flex items-center text-zinc-900 dark:text-zinc-50 focus:outline-none hover:opacity-70 transition-opacity" aria-expanded="false" aria-haspopup="true">
      <span class="material-symbols-outlined text-[28px] select-none">account_circle</span>
    </button>
    
    <div id="user-dropdown" class="hidden absolute right-0 mt-2 w-48 origin-top-right rounded-lg bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 shadow-xl ring-1 ring-black ring-opacity-5 focus:outline-none z-50 transition-all duration-300 ease-out">
      <div class="py-2" role="none">
        <div class="px-4 py-2 border-b border-zinc-100 dark:border-zinc-850">
          <p class="text-[9px] font-['Inter'] uppercase tracking-widest text-zinc-400">Logged in as</p>
          <p class="text-xs font-semibold text-zinc-900 dark:text-zinc-100 truncate">{username}</p>
        </div>
        <a href="/admin" class="flex items-center gap-2 px-4 py-3 text-[11px] font-['Inter'] uppercase tracking-[0.15em] font-semibold text-zinc-700 dark:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-zinc-800 hover:text-zinc-900 dark:hover:text-zinc-50 transition-colors duration-200" role="menuitem">
          <span class="material-symbols-outlined text-[18px]">dashboard</span>
          <span>DASHBOARD</span>
        </a>
        <a href="/logout" class="flex items-center gap-2 px-4 py-3 text-[11px] font-['Inter'] uppercase tracking-[0.15em] font-semibold text-red-650 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-950/30 transition-colors duration-200" role="menuitem">
          <span class="material-symbols-outlined text-[18px]">logout</span>
          <span>LOG OUT</span>
        </a>
      </div>
    </div>
  </div>
) : (
  <a href="/mashok" class="flex items-center text-zinc-900 dark:text-zinc-50 hover:opacity-70 transition-opacity" title="Login">
    <span class="material-symbols-outlined text-[28px] select-none">account_circle</span>
  </a>
)}
</div>
</nav>

<script is:inline>
  (function() {
    const initMenu = () => {
      const userBtn = document.getElementById('user-menu-button');
      const userDropdown = document.getElementById('user-dropdown');
      
      if (userBtn && userDropdown) {
        // Toggle dropdown on click
        userBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          const isExpanded = userDropdown.classList.toggle('hidden');
          userBtn.setAttribute('aria-expanded', (!isExpanded).toString());
        });
        
        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
          if (!userDropdown.contains(e.target) && !userBtn.contains(e.target)) {
            userDropdown.classList.add('hidden');
            userBtn.setAttribute('aria-expanded', 'false');
          }
        });
      }
    };

    initMenu();
    // Support dynamic SPA updates or view transitions if used
    document.addEventListener('astro:page-load', initMenu);
  })();
</script>

