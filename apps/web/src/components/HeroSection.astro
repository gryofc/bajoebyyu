---
import { Button } from "@workspace/ui/components/button"
---

<section class="relative w-full h-[921px] flex items-center justify-center overflow-hidden">
<div class="absolute inset-0 z-0">
<img class="w-full h-full object-cover grayscale brightness-90" alt="A cinematic, high-fashion lifestyle shot of a model wearing a structured monochrome wool coat, standing in a brutalist architectural setting with sharp shadows. The lighting is cold and atmospheric, emphasizing the 'Quiet Luxury' aesthetic. The overall color palette is restricted to deep blacks, slate greys, and stark whites, reflecting a minimalist and sophisticated mood." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBcNBc9kNkGe-clIbL3sLkf9__-76amiFbmyW2BfAJac4z1WF-MuSFvKzPlastTzoJJPGMfi8fe0noHn5jDUpiqzSTI36OGYMGY8jt18opRNdo0zqDVHeNUCff5I-R1OpobxD1e0ogTkXnmp5fD513euRLc0cShyJOTy0yLVgATYyWCD-TeIQa0Bua--dMbJK0vd1L__4jqtk85L47siOrYZr9rO5XNxHfmzGv32aeL1QVB6Z04d0Tvpi30_ubPif7pNjBtbi-fG_OD">
<div class="absolute inset-0 bg-black/20"></div>
</div>
<div class="relative z-10 text-center text-white px-margin-mobile max-w-4xl mx-auto">
<p class="font-label-caps text-label-caps mb-6 tracking-[0.4em] text-white/80">ESTABLISHED MMXXVI</p>
<h2 class="font-display-xl text-display-xl mb-8 uppercase">YOUR MODERN<br>PARTNER IN STYLE</h2>
<p class="font-body-lg text-body-lg text-white/90 max-w-2xl mx-auto mb-12">
    A clinical exploration of architectural silhouettes and textile precision. We define the intersection of silent authority and uncompromising quality.
</p>
<div class="flex flex-col sm:flex-row gap-4 justify-center">
<a href="/catalog"><Button className="rounded-none h-auto px-10 py-5 bg-white !text-black font-label-caps text-label-caps transition-all hover:!bg-black hover:!text-white border border-white" size="lg">EXPLORE COLLECTION</Button></a>
<Button variant="outline" className="rounded-none h-auto px-10 py-5 bg-transparent text-white font-label-caps text-label-caps border border-white hover:bg-white hover:text-black transition-all" size="lg">VIEW LOOKBOOK</Button>
</div>
</div>
</section>
