                                            <button class="edit-blog-btn material-symbols-outlined text-secondary hover:text-primary transition-colors duration-150 active:scale-95 cursor-pointer" data-id={blog.id} data-title={blog.title} data-category={blog.category} data-status={blog.status} data-content={blog.content || ''} title="Edit Post">
