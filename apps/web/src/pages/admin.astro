---
import { getItems, getBlogs } from "../lib/db";
import RichTextEditor from "../components/RichTextEditor.jsx";

const blogs = await getBlogs();

// Protect route - Redirect to /mashok if not logged in
const sessionCookie = Astro.cookies.get("session");
if (!sessionCookie) {
  return Astro.redirect("/mashok");
}

const username = sessionCookie.value;

// Read search parameter to support switching tabs
const tab = Astro.url.searchParams.get("tab") || "dashboard";
const activeTab = tab === "blog" ? "blog" : tab === "product" ? "product" : "dashboard";

// Fetch items to count products dynamically
const items = await getItems();
const totalProducts = items.length;

// Filter categories
const categories = [...new Set(items.map(item => item.category))];
const newArrivalsCount = items.filter(item => item.isNew).length;

// Mock database latency/health check
let isDbOnline = true;
try {
  const { getPool } = await import("../lib/db");
  const pool = getPool();
  // Safe timeout to avoid hanging the SSR if MySQL port 3306 is firewalled
  const conn = await Promise.race([
    pool.getConnection(),
    new Promise((_, reject) => setTimeout(() => reject(new Error("Timeout")), 1500))
  ]) as any;
  conn.release();
} catch (e) {
  isDbOnline = false;
}
