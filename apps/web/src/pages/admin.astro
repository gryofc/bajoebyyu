</main>

<script is:inline>
    // Micro-interaction for Metric Cards
    document.querySelectorAll('.MetricCard').forEach(card => {
        card.addEventListener('mouseenter', () => {
            card.style.transform = 'translateY(-2px)';
        });
        card.addEventListener('mouseleave', () => {
            card.style.transform = 'translateY(0px)';
        });
    });

    // Real-time Multi-Criteria Filtering for Blogs
    const filterName = document.getElementById('filter-name');
    const filterCategory = document.getElementById('filter-category');
    const filterDate = document.getElementById('filter-date');
    const filterStatus = document.getElementById('filter-status');
    const blogRows = document.querySelectorAll('.blog-row');

    function applyFilters() {
        const nameVal = filterName ? filterName.value.toLowerCase().trim() : '';
        const categoryVal = filterCategory ? filterCategory.value : 'all';
        const dateVal = filterDate ? filterDate.value : '';
        const statusVal = filterStatus ? filterStatus.value : 'all';

        blogRows.forEach(row => {
            const rowTitle = row.getAttribute('data-title') || '';
            const rowCategory = row.getAttribute('data-category') || '';
            const rowDate = row.getAttribute('data-date') || '';
            const rowStatus = row.getAttribute('data-status') || '';

            const matchesName = !nameVal || rowTitle.includes(nameVal);
            const matchesCategory = categoryVal === 'all' || rowCategory.toLowerCase() === categoryVal.toLowerCase();
            const matchesDate = !dateVal || rowDate === dateVal;
            const matchesStatus = statusVal === 'all' || rowStatus.toLowerCase() === statusVal.toLowerCase();

            if (matchesName && matchesCategory && matchesDate && matchesStatus) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }

    if (filterName) filterName.addEventListener('input', applyFilters);
    if (filterCategory) filterCategory.addEventListener('change', applyFilters);
    if (filterDate) filterDate.addEventListener('change', applyFilters);
    if (filterStatus) filterStatus.addEventListener('change', applyFilters);

    // Show Blog Preview Modal Interaction
    const showModal = document.getElementById('show-blog-modal');
    const showModalContainer = document.getElementById('show-modal-container');
    const closeShowBtn = document.getElementById('close-show-modal');
    const closeShowBtn2 = document.getElementById('close-show-modal-btn');

    function openShowModal(btn) {
        const title = btn.getAttribute('data-title');
        const category = btn.getAttribute('data-category');
        const status = btn.getAttribute('data-status');
        const content = btn.getAttribute('data-content');
        const date = btn.getAttribute('data-date');

        const showTitle = document.getElementById('show-blog-title');
        const showCategory = document.getElementById('show-blog-category');
        const showStatus = document.getElementById('show-blog-status');
        const showContent = document.getElementById('show-blog-content');
        const showDate = document.getElementById('show-blog-date');

        if (showTitle) showTitle.textContent = title || '';
        if (showCategory) showCategory.textContent = (category || '').toUpperCase();
        if (showStatus) {
            showStatus.textContent = (status || '').toUpperCase();
            if (status === 'Published') {
                showStatus.className = 'ml-4 px-2 py-0.5 border border-primary text-[8px] font-bold uppercase tracking-wider text-primary bg-transparent';
            } else {
                showStatus.className = 'ml-4 px-2 py-0.5 border border-outline text-[8px] font-bold uppercase tracking-wider text-secondary opacity-65 bg-transparent';
            }
        }
        if (showContent) showContent.innerHTML = content || 'No content provided.';
        if (showDate) showDate.textContent = `PUBLISHED ON ${date || 'UNKNOWN'}`;

        if (showModal) {
            showModal.classList.remove('opacity-0', 'pointer-events-none');
            showModal.classList.add('opacity-100');
            showModalContainer.classList.remove('translate-y-4');
            showModalContainer.classList.add('translate-y-0');
        }
    }

    function closeShowModal() {
        if (showModal) {
            showModal.classList.remove('opacity-100');
            showModal.classList.add('opacity-0', 'pointer-events-none');
            showModalContainer.classList.remove('translate-y-0');
            showModalContainer.classList.add('translate-y-4');
        }
    }

    document.querySelectorAll('.show-blog-btn').forEach(btn => {
        btn.addEventListener('click', () => openShowModal(btn));
    });

    if (closeShowBtn) closeShowBtn.addEventListener('click', closeShowModal);
    if (closeShowBtn2) closeShowBtn2.addEventListener('click', closeShowModal);
    if (showModal) {
        showModal.addEventListener('click', (e) => {
            if (e.target === showModal) {
                closeShowModal();
            }
        });
    }

    // Modal Interaction
    const openBtn = document.getElementById('open-create-modal');
    const closeBtn = document.getElementById('close-create-modal');
    const cancelBtn = document.getElementById('cancel-create-modal');
    const modal = document.getElementById('create-blog-modal');
    const modalContainer = document.getElementById('create-modal-container');

    function openModal() {
        if (modal) {
            modal.classList.remove('opacity-0', 'pointer-events-none');
            modal.classList.add('opacity-100');
            modalContainer.classList.remove('translate-y-4');
            modalContainer.classList.add('translate-y-0');
        }
    }

    function closeModal() {
        if (modal) {
            modal.classList.remove('opacity-100');
            modal.classList.add('opacity-0', 'pointer-events-none');
            modalContainer.classList.remove('translate-y-0');
            modalContainer.classList.add('translate-y-4');
        }
    }

    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
    
    if (modal) {
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                closeModal();
            }
        });
    }

    // Form Submission
    const createForm = document.getElementById('create-blog-form');

    // Reset and Open Modal for Creating
    if (openBtn) {
        openBtn.addEventListener('click', () => {
            if (createForm) createForm.reset();
            const idInput = document.getElementById('blog-id');
            if (idInput) idInput.value = '';

            const contentInput = document.getElementById('blog-content');
            if (contentInput) {
                contentInput.value = '';
                contentInput.dispatchEvent(new Event('change', { bubbles: true }));
            }

            const modalTitleEl = modal?.querySelector('h3');
            const submitSpan = createForm?.querySelector('button[type="submit"] span');
            if (modalTitleEl) modalTitleEl.textContent = 'Create New Entry';
            if (submitSpan) submitSpan.textContent = 'Publish Entry';

            openModal();
        });
    }

    // Prefill and Open Modal for Editing
    const editButtons = document.querySelectorAll('.edit-blog-btn');
    editButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const title = btn.getAttribute('data-title');
            const category = btn.getAttribute('data-category');
            const status = btn.getAttribute('data-status');
            const content = btn.getAttribute('data-content');

            const idInput = document.getElementById('blog-id');
            const titleInput = document.getElementById('blog-title');
            const categoryInput = document.getElementById('blog-category');
            const statusInput = document.getElementById('blog-status');
            const contentInput = document.getElementById('blog-content');

            if (idInput) idInput.value = id || '';
            if (titleInput) titleInput.value = title || '';
            if (categoryInput) categoryInput.value = category || '';
            if (statusInput) statusInput.value = status || '';
            if (contentInput) {
                contentInput.value = content || '';
                contentInput.dispatchEvent(new Event('change', { bubbles: true }));
            }

            const modalTitleEl = modal?.querySelector('h3');
            const submitSpan = createForm?.querySelector('button[type="submit"] span');
            if (modalTitleEl) modalTitleEl.textContent = 'Edit Entry';
            if (submitSpan) submitSpan.textContent = 'Save Changes';

            openModal();
        });
    });

    if (createForm) {
        createForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(createForm);
            const id = formData.get('id');
            const data = {
                title: formData.get('title'),
                category: formData.get('category'),
                status: formData.get('status'),
                content: formData.get('content')
            };

            const isEdit = id && id.trim() !== '';
            if (isEdit) {
                data.id = id;
            }

            try {
                const response = await fetch('/api/blog', {
                    method: isEdit ? 'PUT' : 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        window.location.reload();
                    } else {
                        alert(`Failed to ${isEdit ? 'update' : 'create'} entry: ` + (result.error || 'Unknown error'));
                    }
                } else {
                    const err = await response.json();
                    alert(`Error ${isEdit ? 'updating' : 'creating'} entry: ` + (err.error || 'Server error'));
                }
            } catch (error) {
                console.error('Error submitting form:', error);
                alert('Connection error. Please try again.');
            }
        });
    }

    // Delete Interaction
    const deleteButtons = document.querySelectorAll('.delete-blog-btn');
    deleteButtons.forEach(btn => {
        btn.addEventListener('click', async () => {
            const blogId = btn.getAttribute('data-id');
            const blogTitle = btn.closest('.blog-row')?.querySelector('span')?.textContent || 'this post';
            if (!confirm(`Are you sure you want to delete "${blogTitle}"?`)) {
                return;
            }

            try {
                const response = await fetch(`/api/blog?id=${blogId}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        window.location.reload();
                    } else {
                        alert('Failed to delete entry: ' + (result.error || 'Unknown error'));
                    }
                } else {
                    const err = await response.json();
                    alert('Error deleting entry: ' + (err.error || 'Server error'));
                }
            } catch (error) {
                console.error('Error deleting blog:', error);
                alert('Connection error. Please try again.');
            }
        });
    });

    // Real-time Multi-Criteria Filtering for Products
    const filterProdName = document.getElementById('filter-product-name');
    const filterProdCategory = document.getElementById('filter-product-category');
    const filterProdIsNew = document.getElementById('filter-product-is-new');
    const productRows = document.querySelectorAll('.product-row');

    function applyProductFilters() {
        const nameVal = filterProdName ? filterProdName.value.toLowerCase().trim() : '';
        const categoryVal = filterProdCategory ? filterProdCategory.value : 'all';
        const isNewVal = filterProdIsNew ? filterProdIsNew.value : 'all';

        productRows.forEach(row => {
            const rowName = row.getAttribute('data-name') || '';
            const rowCategory = row.getAttribute('data-category') || '';
            const rowIsNew = row.getAttribute('data-is-new') || '';

            const matchesName = !nameVal || rowName.includes(nameVal);
            const matchesCategory = categoryVal === 'all' || rowCategory.toLowerCase() === categoryVal.toLowerCase();
            const matchesIsNew = isNewVal === 'all' || rowIsNew === isNewVal;

            if (matchesName && matchesCategory && matchesIsNew) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }

    if (filterProdName) filterProdName.addEventListener('input', applyProductFilters);
    if (filterProdCategory) filterProdCategory.addEventListener('change', applyProductFilters);
    if (filterProdIsNew) filterProdIsNew.addEventListener('change', applyProductFilters);

    // Product Modal Interaction
    const openProdBtn = document.getElementById('open-product-modal');
    const closeProdBtn = document.getElementById('close-product-modal');
    const cancelProdBtn = document.getElementById('cancel-product-modal');
    const prodModal = document.getElementById('create-product-modal');
    const prodModalContainer = document.getElementById('create-product-modal-container');
    const createProdForm = document.getElementById('create-product-form');

    function openProductModal() {
        if (prodModal) {
            prodModal.classList.remove('opacity-0', 'pointer-events-none');
            prodModal.classList.add('opacity-100');
            prodModalContainer.classList.remove('translate-y-4');
            prodModalContainer.classList.add('translate-y-0');
        }
    }

    function closeProductModal() {
        if (prodModal) {
            prodModal.classList.remove('opacity-100');
            prodModal.classList.add('opacity-0', 'pointer-events-none');
            prodModalContainer.classList.remove('translate-y-0');
            prodModalContainer.classList.add('translate-y-4');
        }
    }

    if (closeProdBtn) closeProdBtn.addEventListener('click', closeProductModal);
    if (cancelProdBtn) cancelProdBtn.addEventListener('click', closeProductModal);
    
    if (prodModal) {
        prodModal.addEventListener('click', (e) => {
            if (e.target === prodModal) {
                closeProductModal();
            }
        });
    }

    // Reset and Open Modal for Creating
    if (openProdBtn) {
        openProdBtn.addEventListener('click', () => {
            if (createProdForm) createProdForm.reset();
            const idInput = document.getElementById('product-id');
            if (idInput) idInput.value = '';

            const isNewCheckbox = document.getElementById('product-is-new');
            if (isNewCheckbox) isNewCheckbox.checked = false;

            const modalTitleEl = prodModal?.querySelector('h3');
            const submitSpan = createProdForm?.querySelector('button[type="submit"] span');
            if (modalTitleEl) modalTitleEl.textContent = 'Add New Product';
            if (submitSpan) submitSpan.textContent = 'Add Product';

            openProductModal();
        });
    }

    // Prefill and Open Modal for Editing
    const editProdButtons = document.querySelectorAll('.edit-product-btn');
    editProdButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name');
            const category = btn.getAttribute('data-category');
            const price = btn.getAttribute('data-price');
            const isNew = btn.getAttribute('data-is-new') === 'true';
            const imageUrl = btn.getAttribute('data-image-url');
            const affUrl = btn.getAttribute('data-aff-url');
            const tkpUrl = btn.getAttribute('data-tkp-url');

            const idInput = document.getElementById('product-id');
            const nameInput = document.getElementById('product-name');
            const categoryInput = document.getElementById('product-category');
            const priceInput = document.getElementById('product-price');
            const isNewCheckbox = document.getElementById('product-is-new');
            const imageUrlInput = document.getElementById('product-image-url');
            const affUrlInput = document.getElementById('product-aff-url');
            const tkpUrlInput = document.getElementById('product-tkp-url');

            if (idInput) idInput.value = id || '';
            if (nameInput) nameInput.value = name || '';
            if (categoryInput) categoryInput.value = category || '';
            if (priceInput) priceInput.value = price || '';
            if (isNewCheckbox) isNewCheckbox.checked = isNew;
            if (imageUrlInput) imageUrlInput.value = imageUrl || '';
            if (affUrlInput) affUrlInput.value = affUrl || '';
            if (tkpUrlInput) tkpUrlInput.value = tkpUrl || '';

            const modalTitleEl = prodModal?.querySelector('h3');
            const submitSpan = createProdForm?.querySelector('button[type="submit"] span');
            if (modalTitleEl) modalTitleEl.textContent = 'Edit Product';
            if (submitSpan) submitSpan.textContent = 'Save Changes';

            openProductModal();
        });
    });

    if (createProdForm) {
        createProdForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(createProdForm);
            const id = formData.get('id');
            const data = {
                name: formData.get('name'),
                category: formData.get('category'),
                price: parseFloat(formData.get('price')),
                isNew: document.getElementById('product-is-new').checked,
                image_url: formData.get('image_url'),
                aff_url: formData.get('aff_url'),
                tkp_url: formData.get('tkp_url')
            };

            const isEdit = id && id.trim() !== '';
            if (isEdit) {
                data.id = id;
            }

            try {
                const response = await fetch('/api/product', {
                    method: isEdit ? 'PUT' : 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        window.location.reload();
                    } else {
                        alert(`Failed to ${isEdit ? 'update' : 'create'} product: ` + (result.error || 'Unknown error'));
                    }
                } else {
                    const err = await response.json();
                    alert(`Error ${isEdit ? 'updating' : 'creating'} product: ` + (err.error || 'Server error'));
                }
            } catch (error) {
                console.error('Error submitting product form:', error);
                alert('Connection error. Please try again.');
            }
        });
    }

    // Product Delete Interaction
    const deleteProdButtons = document.querySelectorAll('.delete-product-btn');
    deleteProdButtons.forEach(btn => {
        btn.addEventListener('click', async () => {
            const prodId = btn.getAttribute('data-id');
            const prodName = btn.closest('.product-row')?.querySelector('span')?.textContent || 'this product';
            if (!confirm(`Are you sure you want to delete "${prodName}"?`)) {
                return;
            }

            try {
                const response = await fetch(`/api/product?id=${prodId}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        window.location.reload();
                    } else {
                        alert('Failed to delete product: ' + (result.error || 'Unknown error'));
                    }
                } else {
                    const err = await response.json();
                    alert('Error deleting product: ' + (err.error || 'Server error'));
                }
            } catch (error) {
                console.error('Error deleting product:', error);
                alert('Connection error. Please try again.');
            }
        });
    });
</script>
</body>
</html>
