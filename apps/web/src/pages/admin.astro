            <section class="mb-16 border-b border-primary pb-8 flex flex-col md:flex-row md:items-end justify-between gap-6">
                <div>
                    <h2 class="font-headline-lg text-headline-lg mb-2 uppercase tracking-tight">Blog Management</h2>
                    <p class="font-body-lg text-secondary max-w-2xl opacity-80">Publish collections, product releases, and editorial articles to the public journal.</p>
                </div>
            </section>

            <!-- Control Row -->
            <div class="flex flex-col xl:flex-row justify-between items-stretch xl:items-center gap-6 mb-12 border-b border-outline-variant pb-6">
                <!-- Dynamic Multi-Filters Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 flex-grow max-w-4xl">
                    <!-- Name Filter -->
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-secondary">
                            <span class="material-symbols-outlined text-sm">search</span>
                        </span>
                        <input type="text" id="filter-name" placeholder="SEARCH BY NAME..." class="w-full pl-9 pr-3 py-2 border border-primary bg-surface font-label-caps text-[10px] tracking-wider focus:outline-none focus:ring-0 focus:border-black" />
