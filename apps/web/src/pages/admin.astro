                                    <td class="py-6 font-body-md text-secondary">
                                        {new Date(blog.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                                    </td>
                                    <td class="py-6">
                                        <span class={`px-3 py-1 border text-[10px] font-bold uppercase ${blog.status === 'Published' ? 'border-primary text-primary' : 'border-outline text-secondary opacity-60'}`}>
                                            {blog.status}
                                        </span>
                                    </td>
                                    <td class="py-6 text-right">
                                        <div class="flex items-center justify-end space-x-3">
                                            <button class="show-blog-btn material-symbols-outlined text-secondary hover:text-primary transition-colors duration-150 active:scale-95 cursor-pointer" data-id={blog.id} data-title={blog.title} data-category={blog.category} data-status={blog.status} data-content={blog.content || ''} data-date={new Date(blog.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })} title="Show Post">
                                                visibility
