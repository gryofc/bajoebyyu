---

<Layout title="Collections | BAJOEBYYU - Oversized Streetwear Indonesia" description="Explore our curated collections of oversized streetwear and modern essentials. Temukan gaya oversize lokal karya anak bangsa terbaik di BAJOEBYYU.">
    <style>
        .product-hover-img:hover {
            transform: scale(1.05);
        }
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: #f9f9f9; }
        ::-webkit-scrollbar-thumb { background: #1b1b1b; }
    </style>
    
    <TopNavBar />

    <div class="pt-20 flex min-h-screen" >
        <!-- SideNavBar / Filter Sidebar -->
        <aside class="sticky top-20 left-0 h-[calc(100vh-80px)] w-64 shrink-0 border-r border-zinc-900 bg-white hidden lg:block overflow-y-auto">
            <div class="flex flex-col pt-20 pb-12 gap-8 px-8">
                <div>
                    <h3 class="font-label-caps text-label-caps text-zinc-900 font-black tracking-widest uppercase mb-2">FILTER</h3>
                    <p class="font-label-caps text-[10px] text-zinc-400 tracking-widest uppercase">REFINE BY CATEGORY</p>
                </div>
                <div class="space-y-6">
                    <section>
                        <h4 class="font-label-caps text-[11px] font-bold tracking-widest text-zinc-900 mb-4 uppercase">CATEGORY</h4>
                        <ul class="space-y-3">
                            <li class="category-filter font-label-caps text-[11px] text-zinc-900 font-black border-l-4 border-zinc-900 pl-4 cursor-pointer" data-category="All Collections">All Collections</li>
                            {uniqueCategories.map(cat => (
                                <li class="category-filter font-label-caps text-[11px] text-zinc-400 hover:text-zinc-900 pl-4 transition-all duration-300 cursor-pointer" data-category={cat}>{cat}</li>
                            ))}
                        </ul>
                    </section>
                    <section>
                        <h4 class="font-label-caps text-[11px] font-bold tracking-widest text-zinc-900 mb-4 uppercase">PRICE</h4>
                        <ul class="space-y-3">
                            <li class="price-filter font-label-caps text-[11px] text-zinc-900 font-black border-l-4 border-zinc-900 pl-4 cursor-pointer" data-min="0" data-max="999999999">All Prices</li>
                            <li class="price-filter font-label-caps text-[11px] text-zinc-400 hover:text-zinc-900 pl-4 transition-all duration-300 cursor-pointer" data-min="0" data-max="150000">Under Rp 150.000</li>
                            <li class="price-filter font-label-caps text-[11px] text-zinc-400 hover:text-zinc-900 pl-4 transition-all duration-300 cursor-pointer" data-min="150000" data-max="200000">Rp 150.000 - Rp 200.000</li>
                            <li class="price-filter font-label-caps text-[11px] text-zinc-400 hover:text-zinc-900 pl-4 transition-all duration-300 cursor-pointer" data-min="200000" data-max="999999999">Over Rp 200.000</li>
                        </ul>
                    </section>
                </div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="flex-1 min-w-0 bg-surface min-h-screen px-8 md:px-16 py-12" style="margin-top:2%;">
            <!-- Search & Breadcrumb -->
            <div class="mb-12 flex flex-col md:flex-row justify-between items-end gap-6 border-b border-zinc-200 pb-8">
                <div>
                    <h1 class="font-headline-md text-headline-md text-on-surface uppercase tracking-tight">All Collections</h1>
                    <p class="font-label-caps text-[10px] text-secondary tracking-[0.2em] mt-2">Showing <span id="collection-count">{collections.length}</span> of {collections.length} collections</p>
                </div>
                <div class="w-full md:w-96 relative">
                    <input id="searchInput" class="w-full bg-transparent border-0 border-b border-zinc-900 focus:ring-0 focus:border-black font-label-caps text-[11px] py-2 pl-4 pr-10 placeholder:text-zinc-300" placeholder="SEARCH CATALOGUE" type="text" />
                    <span class="material-symbols-outlined absolute right-0 bottom-2 text-zinc-400" data-icon="search">search</span>
                </div>
            </div>

            <!-- Product Grid -->
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-12 gap-y-20">
                {collections.map((p) => (
                    <div class="catalog-item flex flex-col group cursor-pointer h-full hover:-translate-y-2 hover:shadow-2xl transition-all duration-300 p-2 rounded-xl" data-name={p.name.toLowerCase()} data-category={p.cat} data-price={p.price}>
                        <div class="aspect-[3/4] overflow-hidden bg-surface-container-low mb-6 relative rounded-lg">
                            <a href={p.url} target="_blank" class="block w-full h-full">
                                <img 
                                    class="w-full h-full object-cover transition-transform duration-700 product-hover-img" 
                                    src={p.image}
                                    alt={p.name}
                                />
                            </a>
                            {p.isNew && (
                                <div class="absolute top-4 left-4 bg-white px-3 py-1 border border-zinc-900 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <span class="font-label-caps text-[9px] font-bold text-zinc-900 tracking-widest">NEW ARRIVAL</span>
                                </div>
                            )}
                        </div>
                        <div class="space-y-1">
                            <p class="font-label-caps text-[10px] text-zinc-400 tracking-widest">{p.cat}</p>
                            <h3 class="font-body-md font-bold text-on-surface uppercase tracking-wider">{p.name}</h3>
                            <p class="font-body-md text-[#000]" >Rp {new Intl.NumberFormat('en-US').format(p.price)}</p>
                        </div>
                        <div class="mt-auto pt-6 space-y-2">
                            <a class="block w-full text-center py-4 bg-black text-white font-label-caps text-[11px] tracking-widest hover:bg-[#EE4D2D] transition-colors" href={p.url} target="_blank">SHOP ON SHOPEE</a>
                            <a class="block w-full text-center py-4 bg-transparent border border-black text-black font-label-caps text-[11px] tracking-widest hover:bg-[#00AA5B] hover:border-[#00AA5B] hover:text-white transition-all" href="https://tokopedia.com" target="_blank">GET IT ON TOKOPEDIA</a>
                        </div>
                    </div>
                ))}
            </div>


        </main>
    </div>

    <Footer />
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('searchInput');
        const items = document.querySelectorAll('.catalog-item');
        const categoryFilters = document.querySelectorAll('.category-filter');
        const priceFilters = document.querySelectorAll('.price-filter');
        const countEl = document.getElementById('collection-count');
        
        let currentSearch = '';
        let currentCategory = 'All Collections';
        let currentMinPrice = 0;
        let currentMaxPrice = 999999999;

        function applyFilters() {
            let visibleCount = 0;
            items.forEach((item) => {
                const el = item as HTMLElement;
                const name = el.dataset.name || '';
                const category = el.dataset.category || '';
                const price = parseFloat(el.dataset.price || '0');
                
                const matchSearch = name.includes(currentSearch);
                const matchCategory = currentCategory === 'All Collections' || category === currentCategory;
                const matchPrice = price >= currentMinPrice && price <= currentMaxPrice;

                if (matchSearch && matchCategory && matchPrice) {
                    el.style.display = '';
                    visibleCount++;
                } else {
                    el.style.display = 'none';
                }
            });
            
            if (countEl) countEl.innerText = visibleCount.toString();
        }

        function updateFilters() {
            if (!document.startViewTransition) {
                applyFilters();
            } else {
                document.startViewTransition(() => {
                    applyFilters();
                });
            }
        }

        if (searchInput) {
            searchInput.addEventListener('input', (e) => {
                currentSearch = (e.target as HTMLInputElement).value.toLowerCase();
                updateFilters();
            });
        }
        
        categoryFilters.forEach(btn => {
            btn.addEventListener('click', (e) => {
                categoryFilters.forEach(b => {
                    b.classList.remove('font-black', 'border-l-4', 'border-zinc-900', 'text-zinc-900');
                    b.classList.add('text-zinc-400');
                });
                const target = e.target as HTMLElement;
                target.classList.add('font-black', 'border-l-4', 'border-zinc-900', 'text-zinc-900');
                target.classList.remove('text-zinc-400');
                
                currentCategory = target.dataset.category || 'All Collections';
                updateFilters();
            });
        });

        priceFilters.forEach(btn => {
            btn.addEventListener('click', (e) => {
                priceFilters.forEach(b => {
                    b.classList.remove('font-black', 'border-l-4', 'border-zinc-900', 'text-zinc-900');
                    b.classList.add('text-zinc-400');
                });
                const target = e.target as HTMLElement;
                target.classList.add('font-black', 'border-l-4', 'border-zinc-900', 'text-zinc-900');
                target.classList.remove('text-zinc-400');
                
                currentMinPrice = parseFloat(target.dataset.min || '0');
                currentMaxPrice = parseFloat(target.dataset.max || '999999999');
                updateFilters();
            });
        });
    });
</script>
