---
import Layout from "../layouts/Layout.astro"
import TopNavBar from "../components/TopNavBar.astro"
import Footer from "../components/Footer.astro"
import item  from "../recipes/item.json";

// transform item.json to collections

const collections = item.map((item) => {
    return {
        name: item.name,
        cat: item.category,
        price: item.price,
        isNew: item.isNew,
        image: item.image_url,
        url : item.aff_url
    };
});

const uniqueCategories = [...new Set(collections.map(c => c.cat).filter(Boolean))];
