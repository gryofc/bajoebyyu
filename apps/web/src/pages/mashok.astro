---
import { verifyUser } from "../lib/auth";

let errorMessage = "";
let successMessage = "";

// Check if user is already logged in (GET requests only to allow POST success notifications)
const sessionCookie = Astro.cookies.get("session");
if (sessionCookie && Astro.request.method === "GET") {
  return Astro.redirect("/admin");
}

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const username = formData.get("username")?.toString() || "";
    const password = formData.get("password")?.toString() || "";

    if (!username || !password) {
      errorMessage = "PLEASE ENTER BOTH USERNAME AND PASSWORD.";
    } else {
      const result = await verifyUser(username, password);
      if (result.success) {
        Astro.cookies.set("session", username, {
          path: "/",
          httpOnly: true,
          secure: true,
          maxAge: 60 * 60 * 24 * 7, // 1 week
          sameSite: "lax"
        });
        
        successMessage = `WELCOME BACK, ${username.toUpperCase()}! REDIRECTING...`;
      } else {
        errorMessage = result.error?.toUpperCase() || "INVALID USERNAME OR PASSWORD.";
      }
    }
  } catch (error: any) {
    errorMessage = "AN UNEXPECTED ERROR OCCURRED. PLEASE TRY AGAIN.";
    console.error("[Login Error]", error);
  }
}
